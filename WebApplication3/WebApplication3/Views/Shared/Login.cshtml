@using WebApplication3.ViewModels

@model WebApplication3.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="block-reg background-white">
    <h4 class="center">Добро пожаловать!</h4>
    <form class="frm" method="post" asp-controller="AccountManager" asp-action="Login">
        <div asp-validation-summary="ModelOnly"></div>

        <input class="form-control" asp-for="ReturnUrl" hidden/>

        <div>
            <div class="mrgn">
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
        </div>
        <div>
            <div class="mrgn">
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
        </div>
        <div>
            <input class="enter_submit" type="submit" value="Войти" />
        </div>

    </form>
    <!--
    <form class="frm" method="post" asp-controller="Register" asp-action="Register">
        <div>
            <input class="enter_submit" type="submit" value="Регистрация" />
        </div>
    </form>
    -->
</div>
